# robotsix-cost-monitor deploy environment.
# Copy to .env and adjust as needed:  cp .env.example .env

# Image tag to run. Default tracks the moving `main` tag (continuous deploy via
# Watchtower). Pin to a version (e.g. 1.2.3) to freeze deploys.
IMAGE_TAG=main

# Path to the JSON project config (default: config/projects.json)
# COST_MONITOR_CONFIG=config/projects.json

# Writable runtime-state directory (reconciliation snapshots, analyst proposals)
# COST_MONITOR_DATA=.data

# Host loopback port the dashboard is published on (proxied by nginx).
MONITOR_PORT=8099
