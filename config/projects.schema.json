{
  "$defs": {
    "AnalystConfig": {
      "description": "LLM cost-analyst settings (optional \u2014 disabled without an OpenRouter key).\n\nThe analyst runs a level-2 (llmio tier-2) agent over the deterministic cost\ndigest, with a level-3 sub-agent that drills into the most expensive traces,\nproducing and storing cost-reduction proposals under ``.data/analyst/``.",
      "properties": {
        "openrouter_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Openrouter Key"
        },
        "global_model": {
          "advanced": true,
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Global Model"
        },
        "trace_model": {
          "advanced": true,
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Trace Model"
        },
        "window_hours": {
          "advanced": true,
          "default": 24,
          "title": "Window Hours",
          "type": "integer"
        },
        "top_stages": {
          "advanced": true,
          "default": 8,
          "title": "Top Stages",
          "type": "integer"
        },
        "traces_per_agent": {
          "advanced": true,
          "default": 1,
          "title": "Traces Per Agent",
          "type": "integer"
        },
        "max_trace_analyses": {
          "advanced": true,
          "default": 12,
          "title": "Max Trace Analyses",
          "type": "integer"
        },
        "schedule_hours": {
          "advanced": true,
          "default": 24.0,
          "title": "Schedule Hours",
          "type": "number"
        },
        "langfuse_public_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Langfuse Public Key"
        },
        "langfuse_secret_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Langfuse Secret Key"
        },
        "langfuse_base_url": {
          "advanced": true,
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Langfuse Base Url"
        },
        "langfuse_project_id": {
          "advanced": true,
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Langfuse Project Id"
        }
      },
      "title": "AnalystConfig",
      "type": "object"
    },
    "ProjectConfig": {
      "description": "One Langfuse project to monitor.",
      "properties": {
        "name": {
          "title": "Name",
          "type": "string"
        },
        "public_key": {
          "pattern": "^pk-lf-",
          "title": "Public Key",
          "type": "string"
        },
        "secret_key": {
          "pattern": "^sk-lf-",
          "title": "Secret Key",
          "type": "string"
        },
        "base_url": {
          "advanced": true,
          "default": "https://cloud.langfuse.com",
          "title": "Base Url",
          "type": "string"
        },
        "openrouter_key": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Openrouter Key"
        }
      },
      "required": [
        "name",
        "public_key",
        "secret_key"
      ],
      "title": "ProjectConfig",
      "type": "object"
    },
    "Settings": {
      "description": "Global dashboard settings.",
      "properties": {
        "default_window_hours": {
          "advanced": true,
          "default": 168,
          "title": "Default Window Hours",
          "type": "integer"
        },
        "cache_ttl_seconds": {
          "advanced": true,
          "default": 60,
          "title": "Cache Ttl Seconds",
          "type": "integer"
        },
        "reconcile_tolerance_usd": {
          "advanced": true,
          "default": 1.0,
          "title": "Reconcile Tolerance Usd",
          "type": "number"
        },
        "reconcile_schedule_hours": {
          "advanced": true,
          "default": 24.0,
          "title": "Reconcile Schedule Hours",
          "type": "number"
        },
        "subscription_call_cap": {
          "advanced": true,
          "default": 0,
          "title": "Subscription Call Cap",
          "type": "integer"
        },
        "analyst": {
          "$ref": "#/$defs/AnalystConfig"
        }
      },
      "title": "Settings",
      "type": "object"
    }
  },
  "description": "Top-level config: the projects to monitor + global settings.",
  "properties": {
    "projects": {
      "items": {
        "$ref": "#/$defs/ProjectConfig"
      },
      "title": "Projects",
      "type": "array"
    },
    "settings": {
      "$ref": "#/$defs/Settings"
    }
  },
  "title": "Config",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema"
}
