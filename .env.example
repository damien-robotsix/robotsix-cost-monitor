# Path to the JSON project configuration file.
# Default: config/projects.json (relative to repo root)
# COST_MONITOR_CONFIG=config/projects.json

# Path to the runtime-state directory (reconciliation snapshots, analyst proposals).
# Default: .data (relative to repo root)
# In a container this must point at a writable/persisted path.
# COST_MONITOR_DATA=.data

# Log format: "json" (default, for production) or "console" (coloured, for dev)
# LOG_FORMAT=json
